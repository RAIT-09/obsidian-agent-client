{
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git stash push:*)",
      "Bash(git pull:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(git checkout:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:check:*)",
      "Bash(npm run format:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(xargs:*)",
      "Bash(python3:*)",
      "Bash(npx eslint:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "obsidian-mcp-server",
    "google-workspace",
    "miro",
    "imap",
    "airtable",
    "chrome-devtools"
  ]
}
